# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-32-chars-minimum-random-string
DEBUG=true

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://calendario:calendario@localhost:5432/calendario_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth (Sprint 2) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─── Fernet (cifrado de tokens OAuth) ─────────────────────────────────────────
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── Push Notifications (Sprint 5) ────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ─── Email (Sprint 5) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@tudominio.com

# ─── GCP / Cloud Run (Sprint 7) ───────────────────────────────────────────────
GCP_PROJECT_ID=
CLOUD_SQL_INSTANCE=
